pipeline {
    agent any

    tools {
        maven 'maven'
    }

    environment {
        SONAR_IP = '172.31.36.164'
        ECR_REGISTRY = "907260787494.dkr.ecr.us-east-1.amazonaws.com"
        ECR_REPOSITORY = 'devsecops_project'
        IMAGE_TAG = 'latest'
        IMAGE_REPO = "${ECR_REGISTRY}/${ECR_REPOSITORY}"
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vishwajeetkore/devsecops-project2.git'
            }
        }

        stage('TRIVY FS Scan') {
            steps {
                sh 'trivy fs --exit-code 1 --severity HIGH,CRITICAL .'
            }
        }
        //  -Dsonar.qualitygate.wait=false this must be true remember  -Dsonar.qualitygate.wait=true
        stage('Build & Sonar Scan') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh """
                        mvn clean verify sonar:sonar \
                        -Dsonar.projectKey=devsecops-project2 \
                        -Dsonar.host.url=http://${SONAR_IP}:9000 \
                        -Dsonar.token=${SONAR_TOKEN} \
                        -Dsonar.qualitygate.wait=false
                    """
                }
            }
        }
        stage ('Login to ECR'){
            steps {
                sh ''' 
                aws ecr get-login-password --region us-east-1 | \
                docker login --username AWS --password-stdin $ECR_REGISTRY
                '''
            }
        }
stage('Docker Build') {
    steps {
        // Using double quotes (") for the sh step so Jenkins correctly resolves the variables
        sh """
        docker build \
          --platform linux/amd64 \
          -t "${IMAGE_REPO}:${BUILD_NUMBER}" \
          -t "${IMAGE_REPO}:latest" .
        """
    }
}

stage('Trivy Image Scan') {
    steps {
        // We set BOTH the cache directory and the system TMPDIR to the workspace
        withEnv([
            "TRIVY_CACHE_DIR=${WORKSPACE}/.trivycache",
            "TMPDIR=${WORKSPACE}/.trivytmp"
        ]) {
            sh '''
                mkdir -p "$TRIVY_CACHE_DIR"
                mkdir -p "$TMPDIR"
                trivy image --image-src docker --exit-code 0 --severity HIGH,CRITICAL "$IMAGE_REPO:$BUILD_NUMBER"
            '''
        }
    }
}
        
        
        stage ('Docker Push') {
            steps {
                sh 'docker push "$IMAGE_REPO:$BUILD_NUMBER"'
                sh 'docker push "$IMAGE_REPO:latest"'
            }
        }
        
        stage('Update Deployment Manifest') {
            steps {
                sh '''
                    sed -i "s|image:.*|image: $IMAGE_REPO:$BUILD_NUMBER|g" deploy-svc.yaml
                    cat deploy-svc.yaml
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    kubectl apply -f deploy-svc.yaml

                    kubectl rollout status deployment/devsecops-demo --timeout=120s || {
                        echo "Deployment failed. Rolling back..."
                        kubectl rollout undo deployment/devsecops-demo || true
                        exit 1
                    }
                '''
            }
        }
    }
    }
